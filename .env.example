# OpenAI (Task 10 - Generation)
OPENAI_API_KEY=sk-xxx

# Jina AI (Task 7 - Reranking, optional)
JINA_API_KEY=jina_xxx

# PageIndex (Task 8 - Vectorless RAG)
PAGEINDEX_API_KEY=pi_xxx

# Weaviate Cloud (Task 4, optional - can use local Docker instead)
WEAVIATE_URL=https://xxx.weaviate.network
WEAVIATE_API_KEY=xxx

# Embedding model for Task 4 (OpenAI-compatible router)
# Priority in code: NINEROUTER_API_KEY -> OPENROUTER_API_KEY -> OPENAI_API_KEY
NINEROUTER_API_KEY=sk-xxx
OPENROUTER_API_KEY=sk-or-xxx
EMBEDDING_BASE_URL=https://api.9router.com/v1
EMBEDDING_MODEL=openrouter/openai/text-embedding-3-small

# Generation model for Task 10 (OpenAI-compatible router)
GENERATION_BASE_URL=https://api.9router.com/v1
GENERATION_MODEL=groq/llama-3.3-70b-versatile

# Other embedding providers (optional)
# COHERE_API_KEY=xxx
